# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (only this user can use the bot)
OWNER_TELEGRAM_ID=

# Google OAuth client credentials (Desktop app type)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where the OAuth refresh token is stored
# Local default: ./data/token.json
# Docker Compose: use /app/data/token.json
GOOGLE_TOKEN_PATH=./data/token.json

# Optional base folder in Google Drive (empty = My Drive root)
DRIVE_ROOT_FOLDER_ID=

# Folder path used when a PDF has no caption
DEFAULT_FOLDER_PATH=Telegram

# Log level: debug, info, warn, error
LOG_LEVEL=info
